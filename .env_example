# Copy to .env, then fill in the pieces you use.
#
# Minimum for LLM reports: one provider key that matches your configured model.
# Defaults use DeepSeek for reports/nudges and Anthropic as fallback/chat.
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional path overrides.
# ZDROWSKIT_HOME=~/Documents/zdrowskit
# ZDROWSKIT_DB=~/Documents/zdrowskit/health.db
# HEALTH_DATA_DIR=~/Library/Mobile Documents/iCloud~com~ifunography~HealthExport/Documents

# Optional Telegram bot integration.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional email delivery via Resend.
RESEND_API_KEY=
EMAIL_TO=
EMAIL_FROM="zdrowskit <onboarding@resend.dev>"

# Optional model overrides. See README.md for the full routing table.
# ZDROWSKIT_INSIGHTS_MODEL=deepseek/deepseek-v4-pro
# ZDROWSKIT_CHAT_MODEL=anthropic/claude-opus-4-7
